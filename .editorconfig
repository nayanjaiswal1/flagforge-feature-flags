root = true

# ── All files ─────────────────────────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# ── Python ────────────────────────────────────────────────────────────────────
[*.py]
indent_style = space
indent_size = 4
max_line_length = 100

# ── TOML / YAML / JSON ────────────────────────────────────────────────────────
[*.{toml,yaml,yml,json}]
indent_style = space
indent_size = 2

# ── TypeScript / JavaScript / TSX / JSX ──────────────────────────────────────
[*.{ts,tsx,js,jsx}]
indent_style = space
indent_size = 2
max_line_length = 100

# ── Markdown ──────────────────────────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ── Makefile ──────────────────────────────────────────────────────────────────
[Makefile]
indent_style = tab
